generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum LiveSessionStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum ParticipantStatus {
  REQUESTED
  APPROVED
  REJECTED
  JOINED
  LEFT
}

enum MediaType {
  AUDIO
  VIDEO
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  fullName          String
  role              UserRole  @default(STUDENT)
  avatar            String?
  bio               String?
  age               Int?
  phoneNumber       String?
  interest          String?
  mustChangePassword Boolean  @default(false)
  isTeacherApproved Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  taughtCourses     Course[]  @relation("TeacherCourses")
  enrollments       Enrollment[]
  liveSessions      LiveSession[] @relation("TeacherLiveSessions")
  participations    LiveSessionParticipant[]
  progress          StudentProgress[]
  quizAttempts      QuizAttempt[]
  offlineContent    OfflineContent[]
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses     Course[]
}

model Course {
  id          String   @id @default(uuid())
  teacherId   String
  categoryId  String?
  title       String
  description String?
  thumbnail   String?
  price       Float    @default(0)
  level       String   @default("beginner")
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher     User     @relation("TeacherCourses", fields: [teacherId], references: [id])
  category    Category? @relation(fields: [categoryId], references: [id])
  subjects    Subject[]
  enrollments Enrollment[]
  liveSessions LiveSession[]
}

model Subject {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  liveSessions LiveSession[]
  recordings  Recording[]
  lessons     Lesson[]
}

model Enrollment {
  id        String   @id @default(uuid())
  courseId  String
  studentId String
  createdAt DateTime @default(now())

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
}

model LiveSession {
  id                  String            @id @default(uuid())
  courseId            String
  subjectId           String?
  teacherId           String
  roomCode            String            @unique
  status              LiveSessionStatus @default(SCHEDULED)
  isApprovalRequired  Boolean           @default(false)
  youtubeLiveVideoId  String?
  youtubeRecordingId  String?
  startedAt           DateTime?
  endedAt             DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  course              Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subject             Subject?          @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  teacher             User              @relation("TeacherLiveSessions", fields: [teacherId], references: [id], onDelete: Cascade)
  participants        LiveSessionParticipant[]
  recordings          Recording[]
}

model LiveSessionParticipant {
  id            String            @id @default(uuid())
  liveSessionId String
  userId        String
  status        ParticipantStatus @default(REQUESTED)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  liveSession   LiveSession       @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([liveSessionId, userId])
  @@index([liveSessionId, status])
}

model Recording {
  id            String   @id @default(uuid())
  liveSessionId String?
  courseId      String
  subjectId     String?
  youtubeVideoId String?  @unique
  title         String
  description   String?
  videoUrl      String?
  duration      Int?
  recordedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  liveSession   LiveSession? @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  subject       Subject?    @relation(fields: [subjectId], references: [id], onDelete: SetNull)
}

model Lesson {
  id          String   @id @default(uuid())
  subjectId   String
  title       String
  description String?
  content     String?
  videoUrl    String?
  duration    Int?
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  resources   LessonResource[]
  progress    StudentProgress[]
  quizzes     Quiz[]
}

model LessonResource {
  id          String   @id @default(uuid())
  lessonId    String
  title       String
  type        String
  url         String
  fileSize    Int?
  createdAt   DateTime @default(now())

  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model StudentProgress {
  id          String   @id @default(uuid())
  studentId   String
  lessonId    String
  completed   Boolean  @default(false)
  progress    Int      @default(0)
  lastAccessed DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
}

model Quiz {
  id          String   @id @default(uuid())
  lessonId    String
  title       String
  description String?
  passingScore Int     @default(70)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions   QuizQuestion[]
  attempts    QuizAttempt[]
}

model QuizQuestion {
  id          String   @id @default(uuid())
  quizId      String
  question    String
  options     String
  correctAnswer Int
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id          String   @id @default(uuid())
  quizId      String
  studentId   String
  score       Int
  answers     String
  completedAt DateTime @default(now())

  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model OfflineContent {
  id          String   @id @default(uuid())
  studentId   String
  lessonId    String
  downloaded  Boolean  @default(false)
  downloadedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
}
